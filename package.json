{
  "name": "pm-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names api,web --prefix-colors cyan,magenta \"node --env-file=.env --import tsx src/api/server.ts\" \"npm --prefix web run dev\"",
    "dev:api": "node --env-file=.env --import tsx src/api/server.ts",
    "start": "node --env-file=.env --import tsx src/api/server.ts",
    "setup": "tsx scripts/setup.ts",
    "typecheck": "tsc --noEmit",
    "evals": "node --env-file=.env --import tsx evals/run-evals.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.174",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
